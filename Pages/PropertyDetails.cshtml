@page
@model CO5078_GuestHouse_Dynamic.Pages.PropertyDetailsModel

@*Property details section showing selected property information *@
<section class="property-summary">
    <h2>Property Details</h2>

    @if (Model.PropertyItem != null)
    {
        <h3>@Model.PropertyItem.Title</h3>

        <img src="@Url.Content("~" + Model.PropertyItem.MainImage)" alt="Property Image" width="600" />

        <p>@Model.PropertyItem.Description</p>

        <p><strong>Location:</strong> @Model.PropertyItem.Location</p>
        <p><strong>Price Per Night:</strong> £@Model.PropertyItem.PricePerNight</p>
        <p><strong>Features:</strong> @Model.PropertyItem.Features</p>

        @if (Model.Images.Count > 0)
        {
            <h3>More Images</h3>

            @*Additional gallery images related to the property*@ 
            <section class="gallery">
            <h2>Property Gallery</h2>
                @foreach (var image in Model.Images)
                {
                    <div class="gallery-item">
                        <img src="@Url.Content("~" + image.ImagePath)" alt="@image.Caption" />
                        <div class="overlay">@image.Caption</div>
                    </div>
                }
            </section>
        }
    }
    else
    {
        <p>No property found.</p>
    }
</section>